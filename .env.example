# Set to "true" for local development with mock data, "false" for real backend
NEXT_PUBLIC_DEV_BYPASS=false

# Backend URL for server-side proxy routes (no NEXT_PUBLIC_ prefix)
# All API calls go through /api/proxy which forwards to this backend
BACKEND_URL=http://localhost:3000

# Must match the backend's JWT_SECRET for JWT verification in /api/auth/me
AUTH_SECRET=change-me-to-match-backend-JWT_SECRET
